---
const {
  title = "AzaNexis | Software inteligente para negocios",
  description = "Plataforma de software, automatización e inteligencia artificial para profesionales, negocios y empresas."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

  <!-- Open Graph / WhatsApp / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://nexishub-web.pages.dev/" />
    <meta property="og:image" content="https://nexishub-web.pages.dev/azanexis-og.jpg" />
    <meta property="og:image:secure_url" content="https://nexishub-web.pages.dev/azanexis-og.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://nexishub-web.pages.dev/azanexis-og.jpg" />



  </head>

  <body>
    <slot />

    <footer class="site-legal-footer">
      <div class="container legal-footer-inner">
        <div>
          <strong>AzaNexis Digital Systems</strong>
          <span>NexisHub Platform</span>
        </div>

        <nav class="legal-footer-links" aria-label="Enlaces legales">
          <a href="/privacidad">Privacidad</a>
          <a href="/terminos">Términos</a>
          <a href="/soporte">Soporte</a>
          <a href="mailto:azanexis@gmail.com">Contacto</a>
        </nav>
      </div>
    </footer>
  </body>

</html>

<style is:global>
  :root {
    --bg: #050505;
    --bg-soft: #0b0b0d;
    --bg-card: #111114;
    --bg-card-2: #17171b;
    --text: #f6f7fb;
    --muted: #a9a9b2;
    --muted-2: #73737d;
    --line: rgba(255, 255, 255, 0.10);
    --accent: #ff6a00;
    --accent-2: #ff8a1f;
    --accent-3: #ffb067;
    --glow: rgba(255, 106, 0, 0.38);
    --glow-strong: rgba(255, 106, 0, 0.62);
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 16px;
    --max: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 70% 8%, rgba(255, 106, 0, 0.22), transparent 34%),
      radial-gradient(circle at 20% 22%, rgba(255, 80, 0, 0.12), transparent 28%),
      linear-gradient(180deg, #050505 0%, #08080a 48%, #030303 100%);
    color: var(--text);
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,.9), transparent 82%);
    z-index: -2;
  }

  body::after {
    content: "";
    position: fixed;
    left: 50%;
    top: -180px;
    width: 220px;
    height: 720px;
    transform: translateX(-50%);
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 106, 0, 0),
      rgba(255, 106, 0, 0.75),
      rgba(255, 255, 255, 0.86),
      rgba(255, 106, 0, 0.32),
      rgba(255, 106, 0, 0)
    );
    filter: blur(22px);
    opacity: 0.35;
    z-index: -1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .container {
    width: min(var(--max), calc(100% - 40px));
    margin: 0 auto;
  }

  .glass {
    background: rgba(17, 17, 20, 0.72);
    border: 1px solid var(--line);
    backdrop-filter: blur(18px);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    padding: 9px 14px;
    border: 1px solid rgba(255, 106, 0, 0.28);
    border-radius: 999px;
    background: rgba(255, 106, 0, 0.08);
    color: #ffd6bd;
    font-size: 13px;
    font-weight: 700;
  }

  .btn {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 18px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 850;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    color: #120802;
    box-shadow: 0 0 34px var(--glow);
  }

  .btn-primary:hover {
    box-shadow: 0 0 54px var(--glow-strong);
  }

  .btn-secondary {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: rgba(255, 106, 0, 0.42);
    background: rgba(255, 106, 0, 0.08);
  }

  .section {
    padding: 86px 0;
  }

  .section-title {
    max-width: 760px;
    margin: 0 auto 34px;
    text-align: center;
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(32px, 5vw, 58px);
    line-height: .98;
    letter-spacing: -0.055em;
  }

  .section-title p {
    margin: 18px auto 0;
    max-width: 650px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.65;
  }

  .accent {
    color: var(--accent-2);
  }

   
   
   
   .site-legal-footer {
    padding: 34px 0;
    border-top: 1px solid var(--line);
    background: rgba(5, 5, 5, 0.72);
  }

  .legal-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .legal-footer-inner strong {
    display: block;
    font-size: 15px;
    color: var(--text);
  }

  .legal-footer-inner span {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 700;
  }

  .legal-footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .legal-footer-links a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 9px 13px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.04);
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
  }

  .legal-footer-links a:hover {
    color: #ffd6bd;
    border-color: rgba(255, 106, 0, 0.34);
    background: rgba(255, 106, 0, 0.08);
  }

  @media (max-width: 780px) {
    .container {
      width: min(100% - 26px, var(--max));
    }

    .section {
      padding: 58px 0;
    }

    .legal-footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .legal-footer-links {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
