---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Panel del cliente | AzaNexis"
  description="Panel de cliente para productos, compras y licencias AzaNexis."
>
  <main class="dashboard-page">
    <section class="dashboard-shell">
      <header class="dashboard-header">
        <div>
          <span class="eyebrow">NexisHub</span>
          <h1>Panel del cliente</h1>
          <p>
            Este será el centro de compras, licencias, descargas, opiniones y comunidad
            para usuarios de AzaNexis. También puedes seguir navegando el catálogo.
          </p>
        </div>

        <div class="header-actions">
          <a href="/">Inicio</a>
          <a href="/softwares">Catálogo</a>
          <a href="/app/dashboard">Mi cuenta</a>
          <button id="logoutBtn" type="button">Cerrar sesión</button>
        </div>
      </header>

      <section id="loadingState" class="panel-card">
        Validando sesión...
      </section>

      <section id="dashboardContent" hidden>
        <article class="panel-card user-card">
          <h2>Tu cuenta</h2>

          <div class="user-grid">
            <div>
              <span>Nombre</span>
              <strong id="fullName">—</strong>
            </div>

            <div>
              <span>Correo</span>
              <strong id="email">—</strong>
            </div>

            <div>
              <span>Apodo público</span>
              <strong id="displayName">—</strong>
            </div>

            <div>
              <span>Rol</span>
              <strong id="role">—</strong>
            </div>
          </div>
        </article>

        <section class="cards-grid">
          <article class="panel-card orders-card">
            <h2>Compras</h2>
            <p id="ordersIntro">Cargando tus compras...</p>
            <div id="ordersList" class="orders-list"></div>
          </article>

          <article class="panel-card licenses-card">
            <h2>Licencias</h2>
            <p id="licensesIntro">Cargando tus licencias...</p>
            <div id="licensesList" class="licenses-list"></div>
          </article>

          <article class="panel-card">
            <h2>Descargas</h2>
            <p>Próximamente podrás descargar instaladores protegidos.</p>
          </article>

          <article class="panel-card">
            <h2>Comunidad</h2>
            <p>Próximamente podrás participar con tu apodo público.</p>
          </article>
        </section>
      </section>

      <p id="messageBox" class="message-box" hidden></p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const token = localStorage.getItem("nexishub_token");
    const loadingState = document.querySelector("#loadingState");
    const dashboardContent = document.querySelector("#dashboardContent");
    const messageBox = document.querySelector("#messageBox");
    const logoutBtn = document.querySelector("#logoutBtn");

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    const logout = () => {
      localStorage.removeItem("nexishub_token");
      localStorage.removeItem("nexishub_user");
      window.location.href = "/app/login";
    };

    logoutBtn.addEventListener("click", logout);

    const formatMoney = (amount, currency) => {
      const value = Number(amount || 0) / 100;
      return new Intl.NumberFormat("es-MX", {
        style: "currency",
        currency: currency || "MXN",
      }).format(value);
    };

    const renderOrders = (orders) => {
      const ordersIntro = document.querySelector("#ordersIntro");
      const ordersList = document.querySelector("#ordersList");

      if (!ordersIntro || !ordersList) return;

      ordersList.innerHTML = "";

      if (!orders.length) {
        ordersIntro.textContent = "Todavía no tienes compras registradas.";
        return;
      }

      ordersIntro.textContent = "Estas son tus compras o solicitudes registradas.";

      orders.forEach((order) => {
        const item = document.createElement("div");
        item.className = "order-item";

        item.innerHTML = `
          <strong>${order.product_name || "Producto"}</strong>
          <span>Orden: ${order.order_number || "—"}</span>
          <span>Estado: ${order.status || "—"}</span>
          <span>Total: ${formatMoney(order.total, order.currency)}</span>
          <small>Fecha: ${order.created_at || "—"}</small>
        `;

        ordersList.appendChild(item);
      });
    };

    const loadOrders = async () => {
      try {
        const response = await fetch(`${API_URL}/me/orders`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          renderOrders([]);
          return;
        }

        renderOrders(data.orders || []);
      } catch (error) {
        renderOrders([]);
      }
    };


    const getLicenseStatusLabel = (status) => {
      const labels = {
        active: "Activa",
        suspended: "Suspendida",
        revoked: "Revocada",
        expired: "Expirada",
      };

      return labels[status] || status || "—";
    };

    const renderLicenses = (licenses) => {
      const licensesIntro = document.querySelector("#licensesIntro");
      const licensesList = document.querySelector("#licensesList");

      if (!licensesIntro || !licensesList) return;

      licensesList.innerHTML = "";

      if (!licenses.length) {
        licensesIntro.textContent = "Todavía no tienes licencias registradas.";
        return;
      }

      licensesIntro.textContent = "Licencias asociadas a tus compras aprobadas.";

      licenses.forEach((license) => {
        const item = document.createElement("div");
        item.className = "license-pro-item";

        item.innerHTML = `
          <div class="license-pro-header">
            <div>
              <span class="license-kicker">Licencia de software</span>
              <strong>${license.product_name || "Producto"}</strong>
            </div>
            <span class="license-status license-status-${license.status || "active"}">
              ${getLicenseStatusLabel(license.status)}
            </span>
          </div>

          <div class="license-code-box">
            <span>Código seguro</span>
            <strong>${license.license_display || "—"}</strong>
          </div>

          <div class="license-meta-grid">
            <div>
              <span>Activaciones</span>
              <strong>${license.activation_count ?? 0} / ${license.max_activations ?? 1}</strong>
            </div>
            <div>
              <span>Orden</span>
              <strong>${license.order_number || "—"}</strong>
            </div>
            <div>
              <span>Creada</span>
              <strong>${license.created_at || "—"}</strong>
            </div>
          </div>

          <div class="license-note">
            La activación principal será con tu correo y contraseña de NexisHub desde NutriPlan Nexis.
          </div>

          <div class="license-actions">
            <button type="button" disabled>Descarga próximamente</button>
            <button type="button" disabled>Activación por PC próximamente</button>
          </div>
        `;

        licensesList.appendChild(item);
      });
    };

    const loadLicenses = async () => {
      try {
        const response = await fetch(`${API_URL}/me/licenses`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          renderLicenses([]);
          return;
        }

        renderLicenses(data.licenses || []);
      } catch (error) {
        renderLicenses([]);
      }
    };

    const loadUser = async () => {
      if (!token) {
        window.location.href = "/app/login";
        return;
      }

      try {
        const response = await fetch(`${API_URL}/me`, {
          method: "GET",
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          logout();
          return;
        }

        const user = data.user;

        document.querySelector("#fullName").textContent = `${user.first_name} ${user.last_name}`;
        document.querySelector("#email").textContent = user.email;
        document.querySelector("#displayName").textContent = user.display_name;
        document.querySelector("#role").textContent = user.role;

        localStorage.setItem("nexishub_user", JSON.stringify(user));

        loadingState.hidden = true;
        dashboardContent.hidden = false;

        loadOrders();
        loadLicenses();
      } catch (error) {
        loadingState.hidden = true;
        showMessage("No se pudo conectar con la API. Intenta nuevamente.", "error");
      }
    };

    loadUser();
  </script>

  <style>
    .dashboard-page {
      min-height: 100vh;
      padding: 42px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .22), transparent 32%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .10), transparent 30%),
        #07070a;
      color: #fff;
    }

    .dashboard-shell {
      width: min(1120px, 100%);
      margin: 0 auto;
    }

    .dashboard-header {
      display: flex;
      justify-content: space-between;
      gap: 24px;
      align-items: flex-start;
      margin-bottom: 24px;
    }

    .eyebrow {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 800;
      font-size: 13px;
    }

    h1 {
      margin: 18px 0 0;
      font-size: clamp(42px, 8vw, 82px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .dashboard-header p {
      max-width: 720px;
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
    }

    .header-actions {
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      max-width: 520px;
    }

    .header-actions a,
    button {
      padding: 13px 16px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      font-size: 14px;
    }

    .header-actions a:hover,
    button:hover {
      background: rgba(255,255,255,.1);
    }

    .panel-card {
      padding: 26px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 28px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.32);
    }

    .panel-card h2 {
      margin: 0;
      font-size: 24px;
      letter-spacing: -0.04em;
    }

    .panel-card p {
      margin: 12px 0 0;
      color: rgba(255,255,255,.68);
      line-height: 1.6;
    }

    .user-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 20px;
    }

    .user-grid div {
      padding: 18px;
      border-radius: 20px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
      min-width: 0;
    }

    .user-grid span {
      display: block;
      color: rgba(255,255,255,.5);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .user-grid strong {
      display: block;
      overflow-wrap: anywhere;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      margin-top: 16px;
    }

    .orders-list {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .order-item {
      display: grid;
      gap: 6px;
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
    }

    .order-item strong {
      color: #fff;
    }

    .order-item span,
    .order-item small {
      color: rgba(255,255,255,.62);
      overflow-wrap: anywhere;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    @media (max-width: 900px) {
      .dashboard-header {
        display: grid;
      }

      .header-actions {
        justify-content: flex-start;
      }

      .user-grid,
      .cards-grid {
        grid-template-columns: 1fr;
      }
    }

    .licenses-list {
      display: grid;
      gap: 12px;
      margin-top: 14px;
    }

    .license-item {
      padding: 16px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
    }

    .license-item strong,
    .license-item span,
    .license-item small {
      display: block;
    }

    .license-item strong {
      color: #fff;
      margin-bottom: 8px;
    }

    .license-item span {
      color: rgba(255,255,255,.78);
      margin-top: 5px;
    }

    .license-item small {
      color: rgba(255,255,255,.52);
      margin-top: 5px;
    }


    .license-pro-item {
      display: grid;
      gap: 14px;
      padding: 18px;
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,.13);
      background:
        linear-gradient(135deg, rgba(255, 106, 0, .10), rgba(255,255,255,.04)),
        rgba(255,255,255,.045);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }

    .license-pro-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .license-kicker,
    .license-code-box span,
    .license-meta-grid span {
      display: block;
      color: rgba(255,255,255,.52);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .license-pro-header strong {
      display: block;
      margin-top: 4px;
      color: #fff;
      font-size: 18px;
    }

    .license-status {
      display: inline-flex;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap;
      background: rgba(255,255,255,.08);
      color: rgba(255,255,255,.78);
    }

    .license-status-active {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .license-code-box {
      padding: 14px;
      border-radius: 18px;
      border: 1px dashed rgba(255, 179, 0, .28);
      background: rgba(0,0,0,.18);
    }

    .license-code-box strong {
      display: block;
      margin-top: 6px;
      color: #ffcf8a;
      font-size: 17px;
      letter-spacing: .03em;
      overflow-wrap: anywhere;
    }

    .license-meta-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .license-meta-grid div {
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
      min-width: 0;
    }

    .license-meta-grid strong {
      display: block;
      margin-top: 5px;
      color: rgba(255,255,255,.88);
      font-size: 13px;
      overflow-wrap: anywhere;
    }

    .license-note {
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(100, 181, 246, .10);
      color: rgba(255,255,255,.72);
      line-height: 1.45;
      font-size: 13px;
    }

    .license-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .license-actions button {
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.52);
      font-weight: 900;
      cursor: not-allowed;
    }

    @media (max-width: 720px) {
      .license-meta-grid {
        grid-template-columns: 1fr;
      }

      .license-pro-header {
        display: grid;
      }
    }

  </style>
</Layout>
