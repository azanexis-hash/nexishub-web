---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Crear cuenta | AzaNexis"
  description="Registro de clientes para NexisHub y productos AzaNexis."
>
  <main class="app-auth-page">
    <section class="auth-card">
      <a class="back-link" href="/">← Volver a AzaNexis</a>

      <span class="eyebrow">Cuenta AzaNexis</span>
      <h1>Crear cuenta</h1>
      <p class="intro">
        Regístrate para acceder al futuro panel de cliente, compras, licencias,
        descargas protegidas y comunidad de usuarios.
      </p>

      <form id="registerForm" class="auth-form">
        <label>
          Nombre
          <input id="firstName" name="first_name" type="text" autocomplete="given-name" required />
        </label>

        <label>
          Apellido
          <input id="lastName" name="last_name" type="text" autocomplete="family-name" required />
        </label>

        <label>
          Correo electrónico
          <input id="email" name="email" type="email" autocomplete="email" required />
        </label>

        <label>
          Contraseña
          <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" required />
          <small>Mínimo 8 caracteres.</small>
        </label>

        <button id="submitBtn" type="submit">Crear cuenta</button>
      </form>

      <p id="messageBox" class="message-box" hidden></p>

      <p class="switch-link">
        ¿Ya tienes cuenta?
        <a href="/app/login">Iniciar sesión</a>
      </p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const form = document.querySelector("#registerForm");
    const messageBox = document.querySelector("#messageBox");
    const submitBtn = document.querySelector("#submitBtn");

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = "Creando cuenta...";
      showMessage("Procesando registro...", "info");

      const payload = {
        first_name: document.querySelector("#firstName").value.trim(),
        last_name: document.querySelector("#lastName").value.trim(),
        email: document.querySelector("#email").value.trim(),
        password: document.querySelector("#password").value,
      };

      try {
        const response = await fetch(`${API_URL}/auth/register`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          showMessage(data.message || "No se pudo crear la cuenta.", "error");
          return;
        }

        localStorage.setItem("nexishub_token", data.token);
        localStorage.setItem("nexishub_user", JSON.stringify(data.user));

        showMessage("Cuenta creada correctamente. Redirigiendo...", "success");

        window.location.href = "/app/dashboard";
      } catch (error) {
        showMessage("Error de conexión con la API. Intenta nuevamente.", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Crear cuenta";
      }
    });
  </script>

  <style>
    .app-auth-page {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 48px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .24), transparent 34%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .12), transparent 32%),
        #07070a;
      color: #fff;
    }

    .auth-card {
      width: min(100%, 560px);
      padding: 34px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 30px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 30px 100px rgba(0,0,0,.45);
    }

    .back-link,
    .switch-link a {
      color: #ff9f43;
      text-decoration: none;
      font-weight: 700;
    }

    .eyebrow {
      display: inline-flex;
      margin-top: 26px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 800;
      font-size: 13px;
    }

    h1 {
      margin: 20px 0 0;
      font-size: clamp(38px, 8vw, 68px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .intro {
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
      font-size: 16px;
    }

    .auth-form {
      display: grid;
      gap: 16px;
      margin-top: 28px;
    }

    label {
      display: grid;
      gap: 8px;
      color: rgba(255,255,255,.86);
      font-weight: 700;
    }

    input {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 16px;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      outline: none;
      font-size: 16px;
    }

    input:focus {
      border-color: rgba(255, 159, 67, .9);
      box-shadow: 0 0 0 4px rgba(255, 159, 67, .12);
    }

    small {
      color: rgba(255,255,255,.5);
      font-weight: 500;
    }

    button {
      margin-top: 6px;
      padding: 15px 18px;
      border: 0;
      border-radius: 18px;
      background: linear-gradient(135deg, #ff6a00, #ffb000);
      color: #111;
      font-size: 16px;
      font-weight: 900;
      cursor: pointer;
    }

    button:disabled {
      opacity: .65;
      cursor: wait;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="success"] {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    .switch-link {
      margin: 20px 0 0;
      color: rgba(255,255,255,.68);
    }
  </style>
</Layout>
