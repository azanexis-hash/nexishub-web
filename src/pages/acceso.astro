---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Acceso de cliente | AzaNexis"
  description="Acceso de clientes a NexisHub y productos AzaNexis."
>
  <main class="access-page">
    <section class="access-shell">
      <a class="back-link" href="/">← Volver al inicio</a>

      <span class="eyebrow">NexisHub Platform</span>
      <h1>Acceso de cliente</h1>
      <p class="intro">
        Entra a tu cuenta para consultar tu perfil, compras, licencias, descargas
        protegidas y futuros beneficios de la comunidad AzaNexis.
      </p>

      <section id="guestAccessCard" class="access-grid">
        <article class="access-card">
          <span>Cliente</span>
          <h2>Mi cuenta</h2>
          <p>
            Acceso para usuarios registrados, compradores y futuros miembros de la
            comunidad. Desde tu cuenta podrás volver al catálogo, revisar productos
            y consultar tus futuras licencias.
          </p>

          <div class="actions">
            <a class="primary-btn" href="/app/login">Iniciar sesión</a>
            <a class="secondary-btn" href="/app/registro">Crear cuenta</a>
            <a class="ghost-btn" href="/softwares">Ver catálogo</a>
          </div>
        </article>
      </section>

      <section id="activeAccessCard" class="access-grid" hidden>
        <article class="access-card active-card">
          <span>Sesión activa</span>
          <h2>Ya ingresaste</h2>
          <p>
            Tu sesión está activa en este navegador. Puedes ir directo a tu panel,
            seguir viendo el catálogo o cerrar sesión.
          </p>

          <div class="account-box">
            <strong id="activeFullName">—</strong>
            <small id="activeEmail">—</small>
            <small id="activeDisplayName">—</small>
          </div>

          <div class="actions">
            <a class="primary-btn" href="/app/dashboard">Ir a mi panel</a>
            <a class="secondary-btn" href="/softwares">Ver catálogo</a>
            <button id="logoutClientBtn" class="ghost-btn" type="button">Cerrar sesión</button>
          </div>
        </article>
      </section>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const guestAccessCard = document.querySelector("#guestAccessCard");
    const activeAccessCard = document.querySelector("#activeAccessCard");
    const logoutClientBtn = document.querySelector("#logoutClientBtn");

    const setText = (selector, value) => {
      const element = document.querySelector(selector);
      if (element) element.textContent = value || "—";
    };

    const clearClientSession = () => {
      localStorage.removeItem("nexishub_token");
      localStorage.removeItem("nexishub_user");
    };

    const showGuestAccess = () => {
      guestAccessCard.hidden = false;
      activeAccessCard.hidden = true;
    };

    const showActiveAccess = (user) => {
      guestAccessCard.hidden = true;
      activeAccessCard.hidden = false;

      setText("#activeFullName", `${user.first_name || ""} ${user.last_name || ""}`.trim());
      setText("#activeEmail", user.email);
      setText("#activeDisplayName", `Apodo: ${user.display_name || "—"}`);
    };

    const validateClientSession = async () => {
      const token = localStorage.getItem("nexishub_token");

      if (!token) {
        showGuestAccess();
        return;
      }

      try {
        const response = await fetch(`${API_URL}/me`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          clearClientSession();
          showGuestAccess();
          return;
        }

        localStorage.setItem("nexishub_user", JSON.stringify(data.user));
        showActiveAccess(data.user);
      } catch (error) {
        showGuestAccess();
      }
    };

    logoutClientBtn.addEventListener("click", () => {
      clearClientSession();
      window.location.href = "/acceso";
    });

    validateClientSession();
  </script>

  <style>
    .access-page {
      min-height: 100vh;
      padding: 54px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .24), transparent 34%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .12), transparent 32%),
        #07070a;
      color: #fff;
    }

    .access-shell {
      width: min(980px, 100%);
      margin: 0 auto;
    }

    .back-link {
      color: #ff9f43;
      text-decoration: none;
      font-weight: 900;
    }

    .eyebrow {
      display: inline-flex;
      margin-top: 42px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 900;
      font-size: 13px;
    }

    h1 {
      margin: 22px 0 0;
      max-width: 900px;
      font-size: clamp(48px, 9vw, 96px);
      line-height: .88;
      letter-spacing: -0.07em;
    }

    .intro {
      max-width: 760px;
      margin: 22px 0 0;
      color: rgba(255,255,255,.72);
      font-size: 18px;
      line-height: 1.7;
    }

    .access-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 18px;
      margin-top: 34px;
    }

    .access-card {
      padding: 34px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 30px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.32);
    }

    .active-card {
      border-color: rgba(255, 179, 0, .24);
    }

    .access-card span {
      display: inline-flex;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-size: 13px;
      font-weight: 900;
    }

    .access-card h2 {
      margin: 20px 0 0;
      font-size: 42px;
      letter-spacing: -0.05em;
    }

    .access-card p {
      max-width: 760px;
      margin: 14px 0 0;
      color: rgba(255,255,255,.68);
      line-height: 1.65;
    }

    .account-box {
      margin-top: 22px;
      padding: 18px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.05);
    }

    .account-box strong,
    .account-box small {
      display: block;
      overflow-wrap: anywhere;
    }

    .account-box strong {
      color: #fff;
      font-size: 20px;
    }

    .account-box small {
      margin-top: 6px;
      color: rgba(255,255,255,.62);
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .primary-btn,
    .secondary-btn,
    .ghost-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 18px;
      border-radius: 16px;
      font-weight: 950;
      text-decoration: none;
      cursor: pointer;
      font-size: 15px;
    }

    .primary-btn {
      border: 0;
      background: linear-gradient(135deg, #ff6a00, #ffb000);
      color: #111;
    }

    .secondary-btn,
    .ghost-btn {
      border: 1px solid rgba(255,255,255,.16);
      color: #fff;
      background: rgba(255,255,255,.06);
    }

    .ghost-btn {
      color: #ffb36b;
    }
  </style>
</Layout>
