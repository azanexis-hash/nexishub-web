---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Activaciones Admin | AzaNexis"
  description="Administración de activaciones por PC de licencias AzaNexis."
>
  <main class="admin-page">
    <section class="admin-shell">
      <header class="admin-header">
        <div>
          <span class="eyebrow">AzaNexis Admin</span>
          <h1>Activaciones por PC</h1>
          <p>
            Visualiza qué cliente activó una licencia, en qué equipo, cuándo fue
            activada y revoca activaciones cuando el cliente cambie de laptop o PC.
          </p>
        </div>

        <div class="header-actions">
          <a href="/">Inicio</a>
          <a href="/softwares">Catálogo</a>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/orders">Órdenes</a>
          <a href="/admin/licenses">Licencias</a>
          <a href="/admin/users">Usuarios</a>
          <button id="logoutBtn" type="button">Cerrar sesión</button>
        </div>
      </header>

      <section class="tools-card">
        <label>
          Buscar activación
          <input id="searchInput" type="search" placeholder="Cliente, correo, producto, licencia, PC o estado..." />
        </label>
        <button id="searchBtn" type="button">Buscar</button>
        <button id="clearBtn" type="button">Limpiar</button>
      </section>

      <section id="loadingState" class="panel-card">
        Cargando activaciones...
      </section>

      <section id="activationsContent" class="activations-grid" hidden></section>

      <p id="messageBox" class="message-box" hidden></p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const token = localStorage.getItem("nexishub_admin_token");
    const loadingState = document.querySelector("#loadingState");
    const activationsContent = document.querySelector("#activationsContent");
    const messageBox = document.querySelector("#messageBox");
    const logoutBtn = document.querySelector("#logoutBtn");
    const searchInput = document.querySelector("#searchInput");
    const searchBtn = document.querySelector("#searchBtn");
    const clearBtn = document.querySelector("#clearBtn");

    const statusLabels = {
      active: "Activa",
      revoked: "Revocada",
    };

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    const hideMessage = () => {
      messageBox.hidden = true;
      messageBox.textContent = "";
    };

    const logout = () => {
      localStorage.removeItem("nexishub_admin_token");
      localStorage.removeItem("nexishub_admin_user");
      window.location.href = "/admin/login";
    };

    const getStatusLabel = (status) => statusLabels[status] || status || "—";

    logoutBtn.addEventListener("click", logout);

    const setActionButtonsDisabled = (disabled) => {
      document.querySelectorAll("[data-revoke-activation]").forEach((button) => {
        button.disabled = disabled;
      });
    };

    const revokeActivation = async (activationId, machineLabel) => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const confirmed = window.confirm(
        `¿Confirmas revocar la activación de "${machineLabel || "este equipo"}"?\n\nEsto liberará el cupo de activación para que el cliente pueda activar otra PC.`
      );

      if (!confirmed) return;

      setActionButtonsDisabled(true);
      showMessage("Revocando activación...", "info");

      try {
        const response = await fetch(`${API_URL}/admin/license-activations/revoke`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            activation_id: activationId,
          }),
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          showMessage(data.message || "No se pudo revocar la activación.", "error");
          setActionButtonsDisabled(false);
          return;
        }

        showMessage("Activación revocada correctamente. El cliente ya puede activar otra PC.", "success");
        await loadActivations();
      } catch (error) {
        showMessage("Error de conexión al revocar la activación.", "error");
        setActionButtonsDisabled(false);
      }
    };

    const renderActivations = (activations) => {
      activationsContent.innerHTML = "";

      if (!activations.length) {
        activationsContent.innerHTML = `
          <article class="activation-card empty-card">
            No se encontraron activaciones.
          </article>
        `;
        return;
      }

      activations.forEach((activation) => {
        const clientName = `${activation.user_first_name || ""} ${activation.user_last_name || ""}`.trim();

        const card = document.createElement("article");
        card.className = "activation-card";

        card.innerHTML = `
          <div class="activation-card-top">
            <div>
              <span class="activation-kicker">Equipo autorizado</span>
              <h2>${activation.machine_label || "Equipo sin nombre"}</h2>
            </div>
            <span class="activation-status activation-status-${activation.status || "active"}">
              ${getStatusLabel(activation.status)}
            </span>
          </div>

          <div class="activation-license-box">
            <span>Licencia</span>
            <strong>${activation.license_display || "—"}</strong>
          </div>

          <div class="activation-info">
            <div>
              <span>Cliente</span>
              <strong>${clientName || "—"}</strong>
              <small>${activation.user_email || "—"}</small>
            </div>

            <div>
              <span>Producto</span>
              <strong>${activation.product_name || "—"}</strong>
              <small>${activation.product_slug || "—"}</small>
            </div>

            <div>
              <span>Huella de PC</span>
              <strong>${activation.machine_fingerprint_hash || "—"}</strong>
              <small>Identificador seguro del equipo</small>
            </div>

            <div>
              <span>Activada</span>
              <strong>${activation.activated_at || "—"}</strong>
              <small>Última validación: ${activation.last_check_at || "—"}</small>
            </div>

            <div>
              <span>Activaciones licencia</span>
              <strong>${activation.activation_count ?? 0} / ${activation.max_activations ?? 1}</strong>
              <small>Estado licencia: ${activation.license_status || "—"}</small>
            </div>

            <div>
              <span>Revocada</span>
              <strong>${activation.revoked_at || "—"}</strong>
              <small>ID: ${activation.id || "—"}</small>
            </div>
          </div>

          <div class="activation-actions">
            ${
              activation.status === "active"
                ? `<button
                    type="button"
                    data-revoke-activation="true"
                    data-activation-id="${activation.id}"
                    data-machine-label="${activation.machine_label || "Equipo"}"
                  >
                    Revocar activación
                  </button>`
                : `<button type="button" disabled>Activación revocada</button>`
            }

            <a href="/admin/licenses">Ver licencias</a>
          </div>
        `;

        activationsContent.appendChild(card);
      });

      document.querySelectorAll("[data-revoke-activation]").forEach((button) => {
        button.addEventListener("click", () => {
          revokeActivation(button.dataset.activationId, button.dataset.machineLabel);
        });
      });
    };

    const loadActivations = async () => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const query = searchInput.value.trim();
      const url = query
        ? `${API_URL}/admin/license-activations?q=${encodeURIComponent(query)}`
        : `${API_URL}/admin/license-activations`;

      loadingState.hidden = false;
      activationsContent.hidden = true;
      hideMessage();

      try {
        const response = await fetch(url, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          logout();
          return;
        }

        renderActivations(data.activations || []);

        loadingState.hidden = true;
        activationsContent.hidden = false;
      } catch (error) {
        loadingState.hidden = true;
        showMessage("No se pudo conectar con la API administrativa.", "error");
      }
    };

    searchBtn.addEventListener("click", loadActivations);

    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      loadActivations();
    });

    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        loadActivations();
      }
    });

    loadActivations();
  </script>

  <style is:global>
    .admin-page {
      min-height: 100vh;
      padding: 42px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .22), transparent 32%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .10), transparent 30%),
        #07070a;
      color: #fff;
    }

    .admin-shell {
      width: min(1320px, 100%);
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      margin-bottom: 24px;
    }

    .eyebrow {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 900;
      font-size: 13px;
    }

    h1 {
      margin: 18px 0 0;
      font-size: clamp(42px, 8vw, 82px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .admin-header p {
      max-width: 760px;
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
    }

    .header-actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
      max-width: 760px;
    }

    .header-actions a,
    button,
    .activation-actions a {
      padding: 13px 16px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      font-weight: 900;
      cursor: pointer;
      text-decoration: none;
      font-size: 14px;
    }

    button:disabled {
      opacity: .45;
      cursor: not-allowed;
    }

    .tools-card,
    .panel-card,
    .activation-card {
      padding: 24px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 28px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.32);
    }

    .tools-card {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px;
      align-items: end;
      margin-bottom: 16px;
    }

    label {
      display: grid;
      gap: 8px;
      color: rgba(255,255,255,.82);
      font-weight: 900;
    }

    input {
      width: 100%;
      box-sizing: border-box;
      padding: 13px 15px;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      outline: none;
      font-size: 15px;
    }

    .activations-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      gap: 18px;
    }

    .activation-card {
      display: grid;
      gap: 16px;
    }

    .activation-card-top {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-start;
    }

    .activation-kicker,
    .activation-license-box span,
    .activation-info span {
      display: block;
      color: rgba(255,255,255,.52);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .activation-card h2 {
      margin: 6px 0 0;
      color: #fff;
      font-size: 24px;
      line-height: 1.1;
    }

    .activation-status {
      display: inline-flex;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      background: rgba(255,255,255,.08);
      white-space: nowrap;
    }

    .activation-status-active {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .activation-status-revoked {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    .activation-license-box {
      padding: 16px;
      border-radius: 20px;
      border: 1px dashed rgba(255, 179, 0, .32);
      background: rgba(0,0,0,.20);
    }

    .activation-license-box strong {
      display: block;
      margin-top: 6px;
      color: #ffcf8a;
      font-size: 18px;
      letter-spacing: .03em;
      overflow-wrap: anywhere;
    }

    .activation-info {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .activation-info div {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
      min-width: 0;
    }

    .activation-info strong {
      display: block;
      margin-top: 5px;
      color: rgba(255,255,255,.9);
      overflow-wrap: anywhere;
    }

    .activation-info small {
      display: block;
      margin-top: 5px;
      color: rgba(255,255,255,.52);
      overflow-wrap: anywhere;
    }

    .activation-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .activation-actions button {
      border-color: rgba(255, 71, 87, .28);
      color: #ffb3ba;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="success"] {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    @media (max-width: 900px) {
      .admin-header,
      .tools-card {
        display: grid;
        grid-template-columns: 1fr;
      }

      .header-actions {
        justify-content: flex-start;
      }

      .activation-info {
        grid-template-columns: 1fr;
      }

      .activations-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
