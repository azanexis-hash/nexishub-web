---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Licencias Admin | AzaNexis"
  description="Administración visual de licencias AzaNexis."
>
  <main class="admin-page">
    <section class="admin-shell">
      <header class="admin-header">
        <div>
          <span class="eyebrow">AzaNexis Admin</span>
          <h1>Licencias</h1>
          <p>
            Visualiza las licencias generadas, su cliente, producto, orden,
            estado y activaciones disponibles. La clave completa no se muestra
            por seguridad.
          </p>
        </div>

        <div class="header-actions">
          <a href="/">Inicio</a>
          <a href="/softwares">Catálogo</a>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/orders">Órdenes</a>
          <a href="/admin/users">Usuarios</a>
          <button id="logoutBtn" type="button">Cerrar sesión</button>
        </div>
      </header>

      <section class="tools-card">
        <label>
          Buscar licencia
          <input id="searchInput" type="search" placeholder="Licencia, cliente, correo, producto, orden o estado..." />
        </label>
        <button id="searchBtn" type="button">Buscar</button>
        <button id="clearBtn" type="button">Limpiar</button>
      </section>

      <section id="loadingState" class="panel-card">
        Cargando licencias...
      </section>

      <section id="licensesContent" class="licenses-grid" hidden></section>

      <p id="messageBox" class="message-box" hidden></p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const token = localStorage.getItem("nexishub_admin_token");
    const loadingState = document.querySelector("#loadingState");
    const licensesContent = document.querySelector("#licensesContent");
    const messageBox = document.querySelector("#messageBox");
    const logoutBtn = document.querySelector("#logoutBtn");
    const searchInput = document.querySelector("#searchInput");
    const searchBtn = document.querySelector("#searchBtn");
    const clearBtn = document.querySelector("#clearBtn");

    const statusLabels = {
      active: "Activa",
      suspended: "Suspendida",
      revoked: "Revocada",
      expired: "Expirada",
    };

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    const hideMessage = () => {
      messageBox.hidden = true;
      messageBox.textContent = "";
    };

    const logout = () => {
      localStorage.removeItem("nexishub_admin_token");
      localStorage.removeItem("nexishub_admin_user");
      window.location.href = "/admin/login";
    };

    const getStatusLabel = (status) => statusLabels[status] || status || "—";

    logoutBtn.addEventListener("click", logout);

    const renderLicenses = (licenses) => {
      licensesContent.innerHTML = "";

      if (!licenses.length) {
        licensesContent.innerHTML = `
          <article class="panel-card empty-card">
            No se encontraron licencias.
          </article>
        `;
        return;
      }

      licenses.forEach((license) => {
        const clientName = `${license.user_first_name || ""} ${license.user_last_name || ""}`.trim();

        const card = document.createElement("article");
        card.className = "license-card";

        card.innerHTML = `
          <div class="license-card-top">
            <div>
              <span class="license-kicker">Licencia</span>
              <h2>${license.product_name || "Producto"}</h2>
            </div>
            <span class="status status-${license.status || "active"}">${getStatusLabel(license.status)}</span>
          </div>

          <div class="license-code">
            <span>Código seguro</span>
            <strong>${license.license_display || "—"}</strong>
          </div>

          <div class="license-info">
            <div>
              <span>Cliente</span>
              <strong>${clientName || "—"}</strong>
              <small>${license.user_email || "—"}</small>
            </div>

            <div>
              <span>Orden</span>
              <strong>${license.order_number || "—"}</strong>
              <small>Estado orden: ${license.order_status || "—"}</small>
            </div>

            <div>
              <span>Activaciones</span>
              <strong>${license.activation_count ?? 0} / ${license.max_activations ?? 1}</strong>
              <small>Por PC autorizada</small>
            </div>

            <div>
              <span>Creada</span>
              <strong>${license.created_at || "—"}</strong>
              <small>Vence: ${license.expires_at || "Sin vencimiento"}</small>
            </div>
          </div>

          <div class="license-actions">
            <a href="/admin/orders">Ver órdenes</a>
            <button type="button" disabled>Activaciones próximamente</button>
            <button type="button" disabled>Suspender próximamente</button>
          </div>
        `;

        licensesContent.appendChild(card);
      });
    };

    const loadLicenses = async () => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const query = searchInput.value.trim();
      const url = query
        ? `${API_URL}/admin/licenses?q=${encodeURIComponent(query)}`
        : `${API_URL}/admin/licenses`;

      loadingState.hidden = false;
      licensesContent.hidden = true;
      hideMessage();

      try {
        const response = await fetch(url, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          logout();
          return;
        }

        renderLicenses(data.licenses || []);

        loadingState.hidden = true;
        licensesContent.hidden = false;
      } catch (error) {
        loadingState.hidden = true;
        showMessage("No se pudo conectar con la API administrativa.", "error");
      }
    };

    searchBtn.addEventListener("click", loadLicenses);

    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      loadLicenses();
    });

    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        loadLicenses();
      }
    });

    loadLicenses();
  </script>

  <style>
    .admin-page {
      min-height: 100vh;
      padding: 42px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .22), transparent 32%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .10), transparent 30%),
        #07070a;
      color: #fff;
    }

    .admin-shell {
      width: min(1280px, 100%);
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      margin-bottom: 24px;
    }

    .eyebrow {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 900;
      font-size: 13px;
    }

    h1 {
      margin: 18px 0 0;
      font-size: clamp(42px, 8vw, 82px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .admin-header p {
      max-width: 760px;
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
    }

    .header-actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
      max-width: 680px;
    }

    .header-actions a,
    button,
    .license-actions a {
      padding: 13px 16px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      font-weight: 900;
      cursor: pointer;
      text-decoration: none;
      font-size: 14px;
    }

    button:disabled {
      opacity: .45;
      cursor: not-allowed;
    }

    .tools-card,
    .panel-card,
    .license-card {
      padding: 24px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 28px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.32);
    }

    .tools-card {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px;
      align-items: end;
      margin-bottom: 16px;
    }

    label {
      display: grid;
      gap: 8px;
      color: rgba(255,255,255,.82);
      font-weight: 900;
    }

    input {
      width: 100%;
      box-sizing: border-box;
      padding: 13px 15px;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      outline: none;
      font-size: 15px;
    }

    .licenses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 16px;
    }

    .license-card {
      display: grid;
      gap: 16px;
    }

    .license-card-top {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-start;
    }

    .license-kicker,
    .license-code span,
    .license-info span {
      display: block;
      color: rgba(255,255,255,.52);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .license-card h2 {
      margin: 6px 0 0;
      color: #fff;
      font-size: 24px;
    }

    .status {
      display: inline-flex;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      background: rgba(255,255,255,.08);
      white-space: nowrap;
    }

    .status-active {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .license-code {
      padding: 16px;
      border-radius: 20px;
      border: 1px dashed rgba(255, 179, 0, .32);
      background: rgba(0,0,0,.20);
    }

    .license-code strong {
      display: block;
      margin-top: 6px;
      color: #ffcf8a;
      font-size: 18px;
      letter-spacing: .03em;
      overflow-wrap: anywhere;
    }

    .license-info {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .license-info div {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
      min-width: 0;
    }

    .license-info strong {
      display: block;
      margin-top: 5px;
      color: rgba(255,255,255,.9);
      overflow-wrap: anywhere;
    }

    .license-info small {
      display: block;
      margin-top: 5px;
      color: rgba(255,255,255,.52);
      overflow-wrap: anywhere;
    }

    .license-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    @media (max-width: 900px) {
      .admin-header,
      .tools-card {
        display: grid;
        grid-template-columns: 1fr;
      }

      .header-actions {
        justify-content: flex-start;
      }

      .license-info {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
