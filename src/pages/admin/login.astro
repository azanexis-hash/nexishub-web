---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Admin Login | AzaNexis"
  description="Acceso administrativo de AzaNexis."
>
  <main class="admin-login-page">
    <section class="admin-card">
      <a class="back-link" href="/">← Volver a AzaNexis</a>

      <span class="eyebrow">Administración</span>
      <h1>Panel admin</h1>
      <p class="intro">
        Acceso privado para administrar usuarios, métricas, compras, licencias,
        descargas, opiniones y comunidad.
      </p>

      <form id="adminLoginForm" class="admin-form">
        <label>
          Correo administrador
          <input id="email" type="email" autocomplete="email" required />
        </label>

        <label>
          Contraseña
          <input id="password" type="password" autocomplete="current-password" required />
        </label>

        <button id="submitBtn" type="submit">Entrar al panel</button>
      </form>

      <p id="messageBox" class="message-box" hidden></p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const form = document.querySelector("#adminLoginForm");
    const messageBox = document.querySelector("#messageBox");
    const submitBtn = document.querySelector("#submitBtn");

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = "Validando...";
      showMessage("Validando acceso administrador...", "info");

      const payload = {
        email: document.querySelector("#email").value.trim(),
        password: document.querySelector("#password").value,
      };

      try {
        const response = await fetch(`${API_URL}/auth/login`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          showMessage(data.message || "No se pudo iniciar sesión.", "error");
          return;
        }

        if (data.user.role !== "admin") {
          showMessage("Este usuario no tiene permisos de administrador.", "error");
          return;
        }

        localStorage.setItem("nexishub_admin_token", data.token);
        localStorage.setItem("nexishub_admin_user", JSON.stringify(data.user));

        showMessage("Acceso correcto. Redirigiendo...", "success");
        window.location.href = "/admin/dashboard";
      } catch (error) {
        showMessage("Error de conexión con la API.", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Entrar al panel";
      }
    });
  </script>

  <style>
    .admin-login-page {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 48px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .24), transparent 34%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .12), transparent 32%),
        #07070a;
      color: #fff;
    }

    .admin-card {
      width: min(100%, 540px);
      padding: 34px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 30px;
      background: rgba(15,15,18,.9);
      box-shadow: 0 30px 100px rgba(0,0,0,.45);
    }

    .back-link {
      color: #ff9f43;
      text-decoration: none;
      font-weight: 800;
    }

    .eyebrow {
      display: inline-flex;
      margin-top: 26px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 900;
      font-size: 13px;
    }

    h1 {
      margin: 20px 0 0;
      font-size: clamp(42px, 8vw, 72px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .intro {
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
    }

    .admin-form {
      display: grid;
      gap: 16px;
      margin-top: 28px;
    }

    label {
      display: grid;
      gap: 8px;
      color: rgba(255,255,255,.86);
      font-weight: 800;
    }

    input {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 16px;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      outline: none;
      font-size: 16px;
    }

    input:focus {
      border-color: rgba(255, 159, 67, .9);
      box-shadow: 0 0 0 4px rgba(255, 159, 67, .12);
    }

    button {
      margin-top: 6px;
      padding: 15px 18px;
      border: 0;
      border-radius: 18px;
      background: linear-gradient(135deg, #ff6a00, #ffb000);
      color: #111;
      font-size: 16px;
      font-weight: 950;
      cursor: pointer;
    }

    button:disabled {
      opacity: .65;
      cursor: wait;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="success"] {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }
  </style>
</Layout>
