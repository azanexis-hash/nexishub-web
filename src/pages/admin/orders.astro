---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Órdenes Admin | AzaNexis"
  description="Administración de órdenes y solicitudes de compra de AzaNexis."
>
  <main class="admin-page">
    <section class="admin-shell">
      <header class="admin-header">
        <div>
          <span class="eyebrow">AzaNexis Admin</span>
          <h1>Órdenes</h1>
          <p>
            Solicitudes de compra registradas por usuarios. Desde aquí puedes
            cambiar el estado manual de cada orden y generar licencias para
            órdenes aprobadas.
          </p>
        </div>

        <div class="header-actions">
          <a href="/">Inicio</a>
          <a href="/softwares">Catálogo</a>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/orders">Órdenes</a>
          <a href="/admin/users">Usuarios</a>
          <a href="/admin/licenses">Licencias</a>
          <a href="/admin/license-activations">Activaciones</a>
          <button id="logoutBtn" type="button">Cerrar sesión</button>
        </div>
      </header>

      <section class="tools-card">
        <label>
          Buscar orden
          <input id="searchInput" type="search" placeholder="Orden, cliente, correo, producto o estado..." />
        </label>
        <button id="searchBtn" type="button">Buscar</button>
        <button id="clearBtn" type="button">Limpiar</button>
      </section>

      <section id="loadingState" class="panel-card">
        Cargando órdenes...
      </section>

      <section id="ordersContent" class="orders-card" hidden>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Orden</th>
                <th>Cliente</th>
                <th>Producto</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="ordersTableBody"></tbody>
          </table>
        </div>
      </section>

      <p id="messageBox" class="message-box" hidden></p>
    </section>
  </main>

  <script>
    const API_URL = "https://nexis-hub-api.azanexis.workers.dev";

    const token = localStorage.getItem("nexishub_admin_token");
    const loadingState = document.querySelector("#loadingState");
    const ordersContent = document.querySelector("#ordersContent");
    const messageBox = document.querySelector("#messageBox");
    const logoutBtn = document.querySelector("#logoutBtn");
    const searchInput = document.querySelector("#searchInput");
    const searchBtn = document.querySelector("#searchBtn");
    const clearBtn = document.querySelector("#clearBtn");
    const ordersTableBody = document.querySelector("#ordersTableBody");

    const statusLabels = {
      pending: "Pendiente",
      approved: "Aprobada",
      cancelled: "Cancelada",
      refunded: "Reembolsada",
    };

    const formatMoney = (amount, currency) => {
      const value = Number(amount || 0) / 100;
      return new Intl.NumberFormat("es-MX", {
        style: "currency",
        currency: currency || "MXN",
      }).format(value);
    };

    const showMessage = (text, type = "info") => {
      messageBox.hidden = false;
      messageBox.textContent = text;
      messageBox.dataset.type = type;
    };

    const hideMessage = () => {
      messageBox.hidden = true;
      messageBox.textContent = "";
    };

    const logout = () => {
      localStorage.removeItem("nexishub_admin_token");
      localStorage.removeItem("nexishub_admin_user");
      window.location.href = "/admin/login";
    };

    logoutBtn.addEventListener("click", logout);

    const getStatusLabel = (status) => {
      return statusLabels[status] || status || "—";
    };

    const getStatusClass = (status) => {
      if (status === "approved") return "status approved";
      if (status === "cancelled") return "status cancelled";
      if (status === "refunded") return "status refunded";
      return "status pending";
    };

    const setActionButtonsDisabled = (disabled) => {
      document.querySelectorAll("[data-order-action], [data-license-action]").forEach((button) => {
        button.disabled = disabled;
      });
    };

    const updateOrderStatus = async (orderNumber, status) => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const label = getStatusLabel(status);
      const confirmed = window.confirm(`¿Confirmas cambiar la orden ${orderNumber} a "${label}"?`);

      if (!confirmed) {
        return;
      }

      setActionButtonsDisabled(true);
      showMessage(`Actualizando orden ${orderNumber}...`, "info");

      try {
        const response = await fetch(`${API_URL}/admin/orders/update-status`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            order_number: orderNumber,
            status,
          }),
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          showMessage(data.message || "No se pudo actualizar la orden.", "error");
          setActionButtonsDisabled(false);
          return;
        }

        showMessage(`Orden ${orderNumber} actualizada a ${label}.`, "success");
        await loadOrders();
      } catch (error) {
        showMessage("Error de conexión al actualizar la orden.", "error");
        setActionButtonsDisabled(false);
      }
    };

    const generateLicense = async (orderNumber) => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const confirmed = window.confirm(
        `¿Confirmas generar una licencia para la orden ${orderNumber}?`
      );

      if (!confirmed) {
        return;
      }

      setActionButtonsDisabled(true);
      showMessage(`Generando licencia para ${orderNumber}...`, "info");

      try {
        const response = await fetch(`${API_URL}/admin/licenses/generate`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            order_number: orderNumber,
            max_activations: 1,
          }),
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          showMessage(data.message || "No se pudo generar la licencia.", "error");
          setActionButtonsDisabled(false);
          return;
        }

        if (data.license_key_visible_once && data.license_key) {
          showMessage(
            `Licencia generada correctamente. Clave visible una sola vez: ${data.license_key}`,
            "success"
          );
        } else {
          showMessage(data.message || "La orden ya tiene licencia generada.", "success");
        }

        await loadOrders();
      } catch (error) {
        showMessage("Error de conexión al generar la licencia.", "error");
        setActionButtonsDisabled(false);
      }
    };

    const renderStatusButtons = (order) => {
      const orderNumber = order.order_number || "";
      const currentStatus = order.status || "pending";

      const actions = [
        { status: "approved", label: "Aprobar" },
        { status: "pending", label: "Pendiente" },
        { status: "cancelled", label: "Cancelar" },
        { status: "refunded", label: "Reembolsar" },
      ];

      return actions
        .map((action) => {
          const disabled = currentStatus === action.status ? "disabled" : "";

          return `
            <button
              class="status-action status-action-${action.status}"
              type="button"
              data-order-action="true"
              data-order-number="${orderNumber}"
              data-status="${action.status}"
              ${disabled}
            >
              ${action.label}
            </button>
          `;
        })
        .join("");
    };

    const renderLicenseButton = (order) => {
      const orderNumber = order.order_number || "";

      if (order.status !== "approved") {
        return `
          <button
            class="license-generate-action"
            type="button"
            disabled
            title="Primero aprueba la orden"
          >
            Generar licencia
          </button>
        `;
      }

      return `
        <button
          class="license-generate-action"
          type="button"
          data-license-action="true"
          data-order-number="${orderNumber}"
        >
          Generar licencia
        </button>
      `;
    };

    const renderOrders = (orders) => {
      ordersTableBody.innerHTML = "";

      if (!orders.length) {
        ordersTableBody.innerHTML = `
          <tr>
            <td colspan="7" class="empty-cell">No se encontraron órdenes.</td>
          </tr>
        `;
        return;
      }

      orders.forEach((order) => {
        const clientName = `${order.user_first_name || ""} ${order.user_last_name || ""}`.trim();

        const tr = document.createElement("tr");

        tr.innerHTML = `
          <td>
            <strong>${order.order_number || "—"}</strong>
            <small>${order.provider_status || order.provider || "—"}</small>
          </td>
          <td>
            <strong>${clientName || "—"}</strong>
            <small>${order.user_email || "—"}</small>
          </td>
          <td>
            <strong>${order.product_name || "—"}</strong>
            <small>${order.product_slug || "—"}</small>
          </td>
          <td>${formatMoney(order.total, order.currency)}</td>
          <td><span class="${getStatusClass(order.status)}">${getStatusLabel(order.status)}</span></td>
          <td>
            <strong>${order.created_at || "—"}</strong>
            <small>Pago: ${order.paid_at || "—"}</small>
            <small>Cancelado: ${order.cancelled_at || "—"}</small>
            <small>Reembolso: ${order.refunded_at || "—"}</small>
          </td>
          <td>
            <div class="order-actions">
              <div class="status-actions-group">
                ${renderStatusButtons(order)}
              </div>

              <div class="license-actions-group">
                ${renderLicenseButton(order)}
                <a class="view-licenses-link" href="/admin/licenses">Ver licencias</a>
              </div>
            </div>
          </td>
        `;

        ordersTableBody.appendChild(tr);
      });

      document.querySelectorAll("[data-order-action]").forEach((button) => {
        button.addEventListener("click", () => {
          updateOrderStatus(button.dataset.orderNumber, button.dataset.status);
        });
      });

      document.querySelectorAll("[data-license-action]").forEach((button) => {
        button.addEventListener("click", () => {
          generateLicense(button.dataset.orderNumber);
        });
      });
    };

    const loadOrders = async () => {
      if (!token) {
        window.location.href = "/admin/login";
        return;
      }

      const query = searchInput.value.trim();
      const url = query
        ? `${API_URL}/admin/orders?q=${encodeURIComponent(query)}`
        : `${API_URL}/admin/orders`;

      loadingState.hidden = false;
      ordersContent.hidden = true;
      hideMessage();

      try {
        const response = await fetch(url, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          logout();
          return;
        }

        renderOrders(data.orders || []);

        loadingState.hidden = true;
        ordersContent.hidden = false;
      } catch (error) {
        loadingState.hidden = true;
        showMessage("No se pudo conectar con la API administrativa.", "error");
      }
    };

    searchBtn.addEventListener("click", loadOrders);

    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      loadOrders();
    });

    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        loadOrders();
      }
    });

    loadOrders();
  </script>

  <style>
    .admin-page {
      min-height: 100vh;
      padding: 42px 20px;
      background:
        radial-gradient(circle at top left, rgba(255, 106, 0, .22), transparent 32%),
        radial-gradient(circle at bottom right, rgba(255, 179, 0, .10), transparent 30%),
        #07070a;
      color: #fff;
    }

    .admin-shell {
      width: min(1320px, 100%);
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      margin-bottom: 24px;
    }

    .eyebrow {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
      font-weight: 900;
      font-size: 13px;
    }

    h1 {
      margin: 18px 0 0;
      font-size: clamp(42px, 8vw, 82px);
      line-height: .9;
      letter-spacing: -0.06em;
    }

    .admin-header p {
      max-width: 760px;
      margin: 18px 0 0;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
    }

    .header-actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
      max-width: 720px;
    }

    .header-actions a,
    button {
      padding: 13px 16px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      font-weight: 900;
      cursor: pointer;
      text-decoration: none;
      font-size: 14px;
    }

    .header-actions a:hover,
    button:hover {
      background: rgba(255,255,255,.1);
    }

    button:disabled {
      opacity: .42;
      cursor: not-allowed;
    }

    .tools-card,
    .panel-card,
    .orders-card {
      padding: 24px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 28px;
      background: rgba(15,15,18,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.32);
    }

    .tools-card {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px;
      align-items: end;
      margin-bottom: 16px;
    }

    label {
      display: grid;
      gap: 8px;
      color: rgba(255,255,255,.82);
      font-weight: 900;
    }

    input {
      width: 100%;
      box-sizing: border-box;
      padding: 13px 15px;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      outline: none;
      font-size: 15px;
    }

    input:focus {
      border-color: rgba(255, 159, 67, .9);
      box-shadow: 0 0 0 4px rgba(255, 159, 67, .12);
    }

    .table-wrap {
      width: 100%;
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1180px;
    }

    th,
    td {
      padding: 15px 12px;
      text-align: left;
      border-bottom: 1px solid rgba(255,255,255,.08);
      color: rgba(255,255,255,.78);
      vertical-align: top;
    }

    th {
      color: #ffb36b;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    td {
      overflow-wrap: anywhere;
    }

    td strong,
    td small {
      display: block;
    }

    td strong {
      color: #fff;
    }

    td small {
      margin-top: 4px;
      color: rgba(255,255,255,.54);
    }

    .status {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 900;
    }

    .status.pending {
      background: rgba(255, 106, 0, .12);
      color: #ffb36b;
    }

    .status.approved {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .status.cancelled {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    .status.refunded {
      background: rgba(100, 181, 246, .14);
      color: #bbdefb;
    }

    .order-actions {
      display: grid;
      gap: 10px;
      min-width: 300px;
    }

    .status-actions-group,
    .license-actions-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .status-action,
    .license-generate-action,
    .view-licenses-link {
      padding: 9px 11px;
      border-radius: 12px;
      font-size: 12px;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: #fff;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
    }

    .status-action-approved {
      border-color: rgba(35, 213, 120, .32);
      color: #9ff0c1;
    }

    .status-action-pending {
      border-color: rgba(255, 179, 0, .32);
      color: #ffb36b;
    }

    .status-action-cancelled {
      border-color: rgba(255, 71, 87, .32);
      color: #ffb3ba;
    }

    .status-action-refunded {
      border-color: rgba(100, 181, 246, .32);
      color: #bbdefb;
    }

    .license-generate-action {
      border-color: rgba(255, 179, 0, .38);
      color: #ffcf8a;
      background: rgba(255, 106, 0, .11);
    }

    .view-licenses-link {
      color: rgba(255,255,255,.78);
    }

    .empty-cell {
      text-align: center;
      color: rgba(255,255,255,.55);
      padding: 28px;
    }

    .message-box {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      line-height: 1.5;
      background: rgba(255,255,255,.08);
    }

    .message-box[data-type="success"] {
      background: rgba(35, 213, 120, .13);
      color: #9ff0c1;
    }

    .message-box[data-type="error"] {
      background: rgba(255, 71, 87, .14);
      color: #ffb3ba;
    }

    @media (max-width: 900px) {
      .admin-header,
      .tools-card {
        display: grid;
        grid-template-columns: 1fr;
      }

      .header-actions {
        justify-content: flex-start;
      }
    }
  </style>

  <style is:global>
    .order-actions {
      display: grid !important;
      gap: 10px !important;
      min-width: 300px !important;
    }

    .status-actions-group,
    .license-actions-group {
      display: flex !important;
      flex-wrap: wrap !important;
      gap: 8px !important;
    }

    .status-action,
    .license-generate-action,
    .view-licenses-link {
      padding: 9px 11px !important;
      border-radius: 12px !important;
      font-size: 12px !important;
      white-space: nowrap !important;
      border: 1px solid rgba(255,255,255,.14) !important;
      background: rgba(255,255,255,.06) !important;
      color: #fff !important;
      font-weight: 900 !important;
      text-decoration: none !important;
      cursor: pointer !important;
    }

    .license-generate-action {
      border-color: rgba(255, 179, 0, .38) !important;
      color: #ffcf8a !important;
      background: rgba(255, 106, 0, .11) !important;
    }

    .view-licenses-link {
      color: rgba(255,255,255,.78) !important;
    }

    .status-action-approved {
      border-color: rgba(35, 213, 120, .32) !important;
      color: #9ff0c1 !important;
    }

    .status-action-pending {
      border-color: rgba(255, 179, 0, .32) !important;
      color: #ffb36b !important;
    }

    .status-action-cancelled {
      border-color: rgba(255, 71, 87, .32) !important;
      color: #ffb3ba !important;
    }

    .status-action-refunded {
      border-color: rgba(100, 181, 246, .32) !important;
      color: #bbdefb !important;
    }

    .status-action:disabled,
    .license-generate-action:disabled {
      opacity: .42 !important;
      cursor: not-allowed !important;
    }
  </style>
</Layout>
