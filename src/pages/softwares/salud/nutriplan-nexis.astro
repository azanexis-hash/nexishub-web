---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="NutriPlan Nexis | AzaNexis">
  <main class="container simple-product">
    <a href="/softwares/salud">← Volver a Salud</a>
    <span class="pill">NutriPlan Nexis</span>
    <h1>Ficha completa del producto en construcción.</h1>
    <p>
      Aquí colocaremos precio, planes, descarga, preguntas frecuentes,
      actualización de versión, requisitos del sistema y compra protegida.
    </p>
  </main>
</Layout>

<style>
  .simple-product {
    min-height: 100vh;
    padding: 80px 0;
  }

  .simple-product a {
    display: inline-flex;
    margin-bottom: 30px;
    color: var(--muted);
    font-weight: 800;
  }

  .simple-product h1 {
    margin: 24px 0 0;
    font-size: clamp(48px, 8vw, 96px);
    line-height: .88;
    letter-spacing: -0.075em;
  }

  .simple-product p {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.7;
  }
</style>